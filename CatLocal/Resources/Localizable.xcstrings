    },
    "The card, details, and images stay on this iPhone.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kart, ayrıntılar ve görseller bu iPhone'da kalır."
          }
        }
      }
    },
    "The collection requires no account, upload, cloud AI, or model-training use.": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koleksiyonunuz için hesap, yükleme, bulut yapay zekâsı veya model eğitimi gerekmez."
          }
        }
      }
    },
    "The selected photo stays on this iPhone": {
      "comment": "Accessibility and VoiceOver copy. Keep the meaning concise and natural when spoken aloud.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The selected photo stays on this iPhone"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçtiğiniz fotoğraf yalnızca bu iPhone'da kalır"
          }
        }
      }
    },
    "This cannot be undone.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem geri alınamaz."
          }
        }
      }
    },
    "This happens entirely on your iPhone.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her şey iPhone'unuzda gerçekleşir."
          }
        }
      }
    },
    "This permanently removes every saved cat from this iPhone.": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem kayıtlı tüm kedileri bu iPhone'dan kalıcı olarak siler."
          }
        }
      }
    },
    "This photo looks a little unclear": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu fotoğrafı okumakta zorlandım"
          }
        }
      }
    },
    "This photo may need another try": {
      "extractionState": "manual",
