    "Saves this card now. You can edit the name, design, and Catlas details later.": {
      "comment": "Accessibility and VoiceOver copy. Keep the meaning concise and natural when spoken aloud.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saves this card now. You can edit the name, design, and Catlas details later."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kartı şimdi kaydeder. Adı, tasarımı ve Catlas ayrıntılarını daha sonra düzenleyebilirsiniz."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvează acest card acum. Poți edita ulterior numele, designul și detaliile Catlas."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisuje tę kartę teraz. Nazwę, wygląd i dane Catlas możesz edytować później."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зберігає цю картку зараз. Ім’я, дизайн і дані Catlas можна змінити пізніше."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αποθηκεύει τώρα αυτή την κάρτα. Μπορείτε να επεξεργαστείτε αργότερα το όνομα, το σχέδιο και τα στοιχεία Catlas."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprema ovu karticu sada. Naziv, dizajn i Catlas podatke možete urediti poslije."
          }
        }
      }
    },
    "See exactly what stays on-device.": {
      "extractionState": "manual",
