    "CatLocal does not request GPS or save coordinates. Catlas labels are typed by you.": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το CatLocal δεν ζητά GPS ούτε αποθηκεύει συντεταγμένες. Εσείς πληκτρολογείτε τις ετικέτες Catlas."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal ne traži GPS niti sprema koordinate. Catlas oznake unosite sami."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal nie prosi o dostęp do GPS ani nie zapisuje współrzędnych. Etykiety Catlas wpisujesz ręcznie."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal nu solicită GPS și nu salvează coordonate. Etichetele Catlas sunt introduse de tine."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal GPS istemez veya koordinat kaydetmez. Catlas etiketlerini siz yazarsınız."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal не запитує GPS і не зберігає координати. Мітки Catlas вводите ви."
