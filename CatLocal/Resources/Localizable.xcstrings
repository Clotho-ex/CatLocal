        }
      },
      "comment": "The user types labels manually. CatLocal does not request GPS access; do not weaken this to merely saying GPS is unused."
    },
    "Unavailable": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanılamıyor"
          }
        }
      }
    },
    "Unplaced for now": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz bir anı yeri yok"
          }
        }
      }
    },
    "Use English": {
      "comment": "Settings button shown when iOS resolves CatLocal to a supported non-English language. Switches CatLocal to English.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İngilizce Kullan"
          }
        }
      }
    },
    "Use System Language": {
      "comment": "Settings button shown while the English fallback is active. Returns CatLocal to the language selected by iOS.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem Dilini Kullan"
          }
        }
      }
    },
    "Use the numbered choices below to select a cat": {
      "comment": "Accessibility and VoiceOver copy. Keep the meaning concise and natural when spoken aloud.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the numbered choices below to select a cat"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir kedi seçmek için aşağıdaki numaralı seçenekleri kullanın"
          }
        }
      }
    },
    "Version": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sürüm"
          }
        }
      }
    },
    "Welcome to CatLocal": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal'a Hoş Geldiniz"
          }
        }
      }
    },
    "Which cat gets the card?": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kart hangi kedinin olsun?"
          }
        }
      }
    },
    "You can still choose a private photo, or enable camera access in Settings.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yine de özel bir fotoğraf seçebilir veya Ayarlar'dan kamera erişimini açabilirsiniz."
          }
        }
      }
    },
    "Your cat encounters stay private": {
      "comment": "CatLocal user-interface copy.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kedi karşılaşmalarınız size özel kalır"
          }
        }
      },
      "extractionState": "manual"
    },
    "Your first card keeps the cat cutout, design, notes, and typed place together.": {
      "comment": "A cat cutout is the cat separated from its photo background.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlk kartınız; kediyi, tasarımını, notlarınızı ve yazdığınız anı yerini bir arada tutar."
          }
        }
      }
    },
    "Add Memory Place": {
      "comment": "Context-menu action that adds a manually typed place to a saved cat.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Anı Yeri Ekle"
          }
        }
      }
    },
    "A brighter, sharper photo will make a better card.": {
      "comment": "Warm recovery guidance after foreground separation fails.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha aydınlık ve net bir fotoğrafla kart çok daha güzel olur."
          }
        }
      }
    },
    "Bottom": {
      "comment": "Section title for the bottom row of accessible photo-selection regions.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alt"
          }
        }
      }
    },
    "CatLocal could not confidently find a cat in this photo.": {
      "comment": "Recoverable Vision error shown when no cat is detected.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu fotoğrafta bir kediyi net olarak bulamadım."
          }
        }
      }
    },
    "CatLocal could not create a clean cutout from this photo. Try a photo with the whole cat in view.": {
      "comment": "Fallback recovery message when foreground separation fails.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kediyi bu fotoğrafta arka plandan temizce ayıramadım. Kedinin tamamının göründüğü başka bir fotoğraf deneyin."
          }
        }
      }
    },
    "CatLocal could not configure the camera.": {
      "comment": "Camera error shown when CatLocal cannot prepare the capture session.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal kamerayı hazırlayamadı."
          }
        }
      }
    },
    "CatLocal could not process this photo on this device right now. Try another photo or try again later.": {
      "comment": "Recoverable Vision error shown when on-device processing is temporarily unavailable.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu fotoğrafı şu anda iPhone'unuzda işleyemedim. Başka bir fotoğraf seçin veya daha sonra yeniden deneyin."
          }
        }
      }
    },
    "CatLocal processes your cat images on-device.": {
      "comment": "Privacy education subtitle spoken by the Loci state view.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal, kedi fotoğraflarını yalnızca iPhone'unuzda işler."
          }
        }
      }
    },
    "Choose photo area": {
      "comment": "Button that opens named regions for accessible cat selection.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotoğraf Alanı Seç"
          }
        }
      }
    },
    "Delete Card": {
      "comment": "Destructive context-menu action for one saved cat card.",
