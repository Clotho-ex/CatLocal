    "A private field journal for the cats you meet.": {
      "comment": "CatLocal user-interface copy.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Karşılaştığınız kediler için size özel bir günlük."
          }
        }
      },
      "extractionState": "manual"
    },
    "A private field journal for the cats you meet. CatLocal turns real encounters into tactile collectible cards using on-device processing and local storage.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Karşılaştığınız kediler için size özel bir günlük. CatLocal, gerçek karşılaşmaları iPhone'unuzda işleyip koleksiyon kartlarına dönüştürür ve yine burada saklar."
          }
        }
      }
    },
    "A private place for the cats you meet.": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Karşılaştığınız kedilere ayrılmış, size özel bir yer."
          }
        }
      }
    },
