    "Finds the cat and removes the background": {
      "comment": "A cutout is the cat separated from the photo background, not a paper cutting.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kediyi bulur ve arka planı kaldırır"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Găsește pisica și elimină fundalul"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wykrywa kota i usuwa tło"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Знаходить кота й видаляє тло"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εντοπίζει τη γάτα και αφαιρεί το φόντο"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pronalazi mačku i uklanja pozadinu"
          }
        }
      },
      "extractionState": "manual"
    },
    "For each cat, CatLocal retains a sanitized, re-encoded original plus its cutout and thumbnail.": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Για κάθε γάτα, το CatLocal διατηρεί ένα καθαρισμένο πρωτότυπο, το απόκομμα και τη μικρογραφία."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Za svaku mačku CatLocal čuva očišćeni i ponovno kodirani izvornik, izrez i minijaturu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dla każdego kota CatLocal zachowuje oczyszczony, ponownie zakodowany oryginał, wycięcie i miniaturę."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pentru fiecare pisică, CatLocal păstrează un original curățat și recodat, plus decupajul și miniatura."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal her kedi için temizlenip yeniden kodlanmış bir orijinali, kesiti ve küçük resmi saklar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Для кожного кота CatLocal зберігає очищений перекодований оригінал, вирізку й мініатюру."
          }
        }
      }
    },
