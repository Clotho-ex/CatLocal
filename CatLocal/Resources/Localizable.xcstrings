    "Welcome to CatLocal": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Καλώς ήρθατε στο CatLocal"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobro došli u CatLocal"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Witaj w CatLocal"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Bun venit la CatLocal"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal'a Hoş Geldiniz"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вітаємо в CatLocal"
          }
        }
      }
    },
    "Which cat gets the card?": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ποια γάτα θα πάρει την κάρτα;"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koja mačka dobiva karticu?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Który kot otrzyma kartę?"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce pisică primește cardul?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kart hangi kedinin olacak?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Який кіт отримає картку?"
          }
        }
      }
    },
    "You can still choose a private photo, or enable camera access in Settings.": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μπορείτε να επιλέξετε ιδιωτική φωτογραφία ή να ενεργοποιήσετε την κάμερα στις Ρυθμίσεις."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Možete odabrati privatnu fotografiju ili omogućiti kameru u Postavkama."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz wybrać prywatne zdjęcie albo włączyć dostęp do aparatu w Ustawieniach."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Poți alege o fotografie privată sau poți activa camera din Configurări."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yine de özel bir fotoğraf seçebilir veya Ayarlar'dan kamera erişimini açabilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете вибрати приватне фото або дозволити доступ до камери в налаштуваннях."
          }
        }
      }
    },
    "Your cat encounters stay private": {
      "comment": "CatLocal user-interface copy.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kedi karşılaşmalarınız gizli kalır"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Întâlnirile tale cu pisici rămân private"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje spotkania z kotami pozostają prywatne"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваші зустрічі з котами залишаються приватними"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι συναντήσεις σας με γάτες παραμένουν ιδιωτικές"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaši susreti s mačkama ostaju privatni"
          }
        }
      },
      "extractionState": "manual"
    },
    "Your first card keeps the cat cutout, design, notes, and typed place together.": {
      "comment": "A cat cutout is the cat separated from its photo background.",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η πρώτη σας κάρτα κρατά μαζί το απόκομμα της γάτας, το σχέδιο, τις σημειώσεις και την τοποθεσία."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša prva kartica čuva izrez mačke, dizajn, bilješke i uneseno mjesto zajedno."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pierwsza karta łączy wycięcie kota, wygląd, notatki i wpisane miejsce."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Primul tău card păstrează împreună decupajul pisicii, designul, notițele și locul introdus."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlk kartınız kedi kesitini, tasarımı, notları ve yazılan konumu bir arada tutar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перша картка поєднує вирізку кота, дизайн, нотатки й введене місце."
          }
        }
      }
    },
    "iOS Reduce Motion always takes priority over Card Motion.": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η Μείωση κίνησης του iOS έχει πάντα προτεραιότητα."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS opcija Smanji kretanje uvijek ima prednost."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Funkcja Ogranicz ruch w iOS ma zawsze pierwszeństwo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Opțiunea Reduceți mișcarea din iOS are întotdeauna prioritate."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS Hareketi Azalt ayarı her zaman Kart Hareketi ayarına göre önceliklidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Функція «Зменшення руху» в iOS завжди має пріоритет."
          }
        }
      }
    }
  },
  "version": "1.0"
}
