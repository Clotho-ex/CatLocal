    "Double tap to choose a zoom level. Swipe up or down to adjust.": {
      "comment": "Accessibility and VoiceOver copy. Keep the meaning concise and natural when spoken aloud.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double tap to choose a zoom level. Swipe up or down to adjust."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yakınlaştırma düzeyi seçmek için çift dokunun. Ayarlamak için yukarı veya aşağı kaydırın."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Atinge de două ori pentru a alege nivelul de zoom. Glisează în sus sau în jos pentru ajustare."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuknij dwukrotnie, aby wybrać poziom powiększenia. Przesuń w górę lub w dół, aby dostosować."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Двічі торкніться, щоб вибрати масштаб. Проведіть угору або вниз, щоб налаштувати."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αγγίξτε δύο φορές για να επιλέξετε επίπεδο ζουμ. Σαρώστε πάνω ή κάτω για ρύθμιση."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodirnite dvaput za odabir razine zuma. Prijeđite gore ili dolje za prilagodbu."
          }
        }
      }
    },
