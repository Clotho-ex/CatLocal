    "A note about this encounter": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μια σημείωση για αυτή τη συνάντηση"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilješka o ovom susretu"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Notatka o tym spotkaniu"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "O notiță despre această întâlnire"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu karşılaşma hakkında bir not"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Нотатка про цю зустріч"
          }
        }
      }
    },
    "A private field journal for the cats you meet.": {
      "comment": "CatLocal user-interface copy.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanıştığınız kediler için özel bir saha günlüğü."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Un jurnal privat pentru pisicile pe care le întâlnești."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prywatny dziennik spotykanych kotów."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Приватний польовий щоденник котів, яких ви зустрічаєте."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ένα ιδιωτικό ημερολόγιο για τις γάτες που συναντάτε."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Privatni terenski dnevnik mačaka koje susrećete."
          }
        }
      },
      "extractionState": "manual"
    },
    "A private field journal for the cats you meet. CatLocal turns real encounters into tactile collectible cards using on-device processing and local storage.": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ένα ιδιωτικό ημερολόγιο για τις γάτες που συναντάτε. Το CatLocal μετατρέπει πραγματικές συναντήσεις σε απτικές συλλεκτικές κάρτες με επεξεργασία στη συσκευή και τοπική αποθήκευση."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Privatni dnevnik mačaka koje susrećete. CatLocal pretvara stvarne susrete u taktilne kolekcionarske kartice uz obradu na uređaju i lokalnu pohranu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prywatny dziennik spotykanych kotów. CatLocal zamienia prawdziwe spotkania w interaktywne karty kolekcjonerskie, przetwarzając je na urządzeniu i zapisując lokalnie."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Un jurnal privat pentru pisicile întâlnite. CatLocal transformă întâlnirile reale în carduri de colecție tactile, folosind procesare pe dispozitiv și stocare locală."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanıştığınız kediler için özel bir saha günlüğü. CatLocal gerçek karşılaşmaları aygıtta işleme ve yerel depolamayla dokunsal koleksiyon kartlarına dönüştürür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Приватний щоденник котів, яких ви зустрічаєте. CatLocal перетворює реальні зустрічі на тактильні колекційні картки завдяки обробці на пристрої й локальному сховищу."
          }
        }
      }
    },
    "A private place for the cats you meet.": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ένας ιδιωτικός χώρος για τις γάτες που συναντάτε."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Privatno mjesto za mačke koje susrećete."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prywatne miejsce dla spotykanych kotów."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Un loc privat pentru pisicile pe care le întâlnești."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanıştığınız kediler için özel bir yer."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Приватне місце для котів, яких ви зустрічаєте."
          }
        }
      }
    },
