      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera henüz hazır değil."
          }
        }
      }
    },
    "The captured photo could not be opened.": {
      "comment": "Camera error shown when captured image data cannot be opened.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çekilen fotoğraf açılamadı."
          }
        }
      }
    },
    "The cat was found, but the cutout could not be created.": {
      "comment": "Recoverable Vision error shown after detection succeeds but foreground separation fails.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kediyi buldum ama arka plandan ayıramadım."
          }
        }
      }
    },
    "The selected cat could not be separated cleanly. Try a photo with more space around them.": {
      "comment": "Warm recovery guidance when the selected cat cannot be separated from the background.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçtiğiniz kediyi arka plandan temizce ayıramadım. Kedinin kadrajda biraz daha rahat olduğu bir fotoğraf deneyin."
          }
        }
      }
    },
    "This photo could not be read. Try another one.": {
      "comment": "Recoverable image error shown when the selected photo cannot be decoded.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu fotoğrafı okuyamadım. Başka bir fotoğraf deneyin."
          }
        }
      }
    },
    "Top": {
      "comment": "Section title for the top row of accessible photo-selection regions.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Üst"
          }
        }
      }
    },
    "Try a brighter photo where your cat is fully visible.": {
      "comment": "Warm recovery guidance shown when no cat can be detected.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kedinin tamamının göründüğü daha aydınlık bir fotoğraf deneyin."
          }
        }
      }
    },
    "Try again in a moment.": {
      "comment": "Brief recovery guidance after an unexpected processing failure.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birazdan yeniden deneyin."
          }
        }
      }
    },
    "Your cards react to touch.": {
      "comment": "Brief hint explaining focused-card interaction.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kartlarınız dokunuşunuza karşılık verir."
          }
        }
      }
    },
    "Your cutout and unsaved details will be lost. Saved cats stay in your collection.": {
      "comment": "Confirmation detail before closing an unsaved cat-card draft.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arka plansız görsel ve kaydedilmemiş bilgiler silinir. Koleksiyonunuzdaki kediler etkilenmez."
          }
        }
      }
    },
    "Your cutout and unsaved details will be lost before the camera opens.": {
      "comment": "Confirmation detail before discarding a draft and reopening the camera.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera açılmadan önce arka plansız görsel ve kaydedilmemiş bilgiler silinir."
          }
        }
      }
    },
    "iOS Reduce Motion always takes priority over Card Motion.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS'taki Hareketi Azalt ayarı, Kart Hareketi'nden her zaman önceliklidir."
          }
        }
      }
    }
