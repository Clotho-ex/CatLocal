    "Includes card details, notes, typed Catlas labels, originals, cutouts, and thumbnails.": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Περιλαμβάνει στοιχεία καρτών, σημειώσεις, ετικέτες Catlas, πρωτότυπα, αποκόμματα και μικρογραφίες."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uključuje podatke kartica, bilješke, unesene Catlas oznake, izvornike, izreze i minijature."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Obejmuje dane kart, notatki, wpisane etykiety Catlas, oryginały, wycięcia i miniatury."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Include detaliile cardurilor, notițele, etichetele Catlas introduse, originalele, decupajele și miniaturile."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kart ayrıntıları, notlar, yazılan Catlas etiketleri, orijinaller, kesitler ve küçük resimler dahildir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Охоплює дані карток, нотатки, введені мітки Catlas, оригінали, вирізки й мініатюри."
          }
        }
