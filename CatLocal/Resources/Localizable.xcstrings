    "Home opens next. Tap Camera when you meet a cat, or choose a private photo.": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Στη συνέχεια ανοίγει η Αρχική. Όταν συναντήσετε γάτα, πατήστε Κάμερα ή επιλέξτε ιδιωτική φωτογραφία."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sljedeća se otvara Početna. Kad sretnete mačku, dodirnite Kamera ili odaberite privatnu fotografiju."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Następnie otworzy się Start. Gdy spotkasz kota, stuknij Aparat albo wybierz prywatne zdjęcie."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Urmează ecranul Acasă. Când întâlnești o pisică, atinge Cameră sau alege o fotografie privată."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sırada Ana Sayfa var. Bir kediyle karşılaştığınızda Kamera'ya dokunun veya özel bir fotoğraf seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Далі відкриється головна. Коли зустрінете кота, торкніть «Камера» або виберіть приватне фото."
          }
        }
      }
    },
    "I couldn't find the cat clearly": {
      "extractionState": "manual",
      "localizations": {
