    "Typed labels only. No GPS is requested.": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μόνο ετικέτες που πληκτρολογείτε. Το CatLocal δεν ζητά πρόσβαση στο GPS."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Samo ručno unesene oznake. CatLocal ne traži pristup GPS-u."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tylko etykiety wpisane ręcznie. CatLocal nie prosi o dostęp do GPS."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Doar etichete introduse manual. CatLocal nu solicită acces la GPS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca elle girdiğiniz etiketler. CatLocal GPS erişimi istemez."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Лише мітки, введені вручну. CatLocal не запитує доступ до GPS."
          }
        }
      },
      "comment": "The user types labels manually. CatLocal does not request GPS access; do not weaken this to merely saying GPS is unused."
    },
