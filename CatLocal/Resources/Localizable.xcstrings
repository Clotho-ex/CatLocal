    "Before storage, CatLocal redraws the selected photo and re-encodes it without source EXIF, GPS, camera/device, or orientation metadata.": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πριν την αποθήκευση, το CatLocal επανασχεδιάζει τη φωτογραφία και την κωδικοποιεί χωρίς EXIF, GPS, στοιχεία κάμερας/συσκευής ή προσανατολισμού."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prije pohrane CatLocal ponovno iscrtava fotografiju i kodira je bez izvornih EXIF, GPS, podataka kamere/uređaja ili orijentacije."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przed zapisem CatLocal ponownie renderuje zdjęcie i koduje je bez źródłowych danych EXIF, GPS, aparatu/urządzenia i orientacji."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înainte de stocare, CatLocal redesenează fotografia și o recodează fără metadate EXIF, GPS, cameră/dispozitiv sau orientare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLocal depolamadan önce seçilen fotoğrafı yeniden çizer ve kaynak EXIF, GPS, kamera/aygıt ya da yön verileri olmadan yeniden kodlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед збереженням CatLocal перемальовує фото й перекодовує його без вихідних EXIF, GPS, даних камери/пристрою та орієнтації."
          }
        }
      }
    },
