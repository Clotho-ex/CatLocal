    "The selected photo stays on this iPhone": {
      "comment": "Accessibility and VoiceOver copy. Keep the meaning concise and natural when spoken aloud.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The selected photo stays on this iPhone"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçilen fotoğraf bu iPhone'da kalır"
          }
        }
      }
    },
    "This cannot be undone.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem geri alınamaz."
          }
        }
      }
    },
    "This happens entirely on your iPhone.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem tamamen iPhone'unuzda gerçekleşir."
          }
        }
      }
    },
    "This permanently removes every saved cat from this iPhone.": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem kayıtlı tüm kedileri bu iPhone'dan kalıcı olarak siler."
          }
        }
      }
    },
    "This photo looks a little unclear": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu fotoğraf biraz belirsiz görünüyor"
          }
        }
      }
    },
    "This photo may need another try": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu fotoğrafı yeniden denemek gerekebilir"
          }
        }
      }
    },
    "Tilt, foil lighting, and reveal motion.": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eğim, folyo ışığı ve ortaya çıkma hareketi."
          }
        }
      }
    },
    "Top center": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Üst orta"
          }
        }
      }
    },
    "Top left": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
