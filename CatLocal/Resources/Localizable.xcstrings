    "The collection requires no account, upload, cloud AI, or model-training use.": {
      "extractionState": "manual",
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η συλλογή δεν απαιτεί λογαριασμό, μεταφόρτωση, τεχνητή νοημοσύνη στο cloud ή χρήση για εκπαίδευση μοντέλων."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zbirka ne zahtijeva račun, prijenos, AI u oblaku niti treniranje modela."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kolekcja nie wymaga konta, przesyłania, AI w chmurze ani użycia do trenowania modeli."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Colecția nu necesită cont, încărcare, AI în cloud sau utilizare pentru antrenarea modelelor."
          }
