      }
    },
    "Saved locally to your collection.": {
      "comment": "Brief confirmation shown after a cat card is saved.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koleksiyonunuza, yalnızca bu iPhone'a kaydedildi."
