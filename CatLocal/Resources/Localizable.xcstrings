    },
    "Try another photo": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Başka bir fotoğraf dene"
          }
        }
      }
    },
    "Try the center": {
      "comment": "CatLocal user-interface copy.",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merkezi deneyin"
          }
        }
      },
      "extractionState": "manual"
    },
    "Typed labels only. No GPS is requested.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca elle girdiğiniz etiketler. CatLocal GPS erişimi istemez."
          }
        }
      },
      "comment": "The user types labels manually. CatLocal does not request GPS access; do not weaken this to merely saying GPS is unused."
    },
    "Unavailable": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanılamıyor"
          }
        }
      }
    },
    "Unplaced for now": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Şimdilik konumsuz"
          }
        }
      }
    },
    "Use English": {
      "comment": "Settings button shown when iOS resolves CatLocal to a supported non-English language. Switches CatLocal to English.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İngilizce Kullan"
          }
        }
      }
    },
    "Use System Language": {
      "comment": "Settings button shown while the English fallback is active. Returns CatLocal to the language selected by iOS.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem Dilini Kullan"
          }
        }
      }
    },
    "Use the numbered choices below to select a cat": {
      "comment": "Accessibility and VoiceOver copy. Keep the meaning concise and natural when spoken aloud.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the numbered choices below to select a cat"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir kedi seçmek için aşağıdaki numaralı seçenekleri kullanın"
