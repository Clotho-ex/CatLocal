      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu taslak silinsin mi?"
          }
        }
      }
    },
    "Explains local privacy before you start collecting.": {
      "comment": "VoiceOver hint for the onboarding privacy step.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koleksiyona başlamadan önce yerel gizliliği açıklar."
          }
        }
      }
    },
    "Finishes onboarding and opens Home. Camera and private photo import remain available when you are ready.": {
      "comment": "VoiceOver hint for the final onboarding action.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanıtımı bitirip Ana Sayfa'yı açar. Hazır olduğunuzda Kamera'yı veya Fotoğraflar'dan seçimi kullanabilirsiniz."
          }
        }
      }
    },
    "Good lighting helps CatLocal make a cleaner cutout.": {
      "comment": "Warm image-quality guidance spoken by the Loci state view.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İyi ışık, kediyi arka plandan daha temiz ayırmama yardımcı olur."
          }
        }
      }
    },
    "Image folders use iOS file protection until the first unlock after restart, are excluded from backups, and are deleted with their cat.": {
      "comment": "Privacy receipt detail. Preserve file protection, backup exclusion, and deletion with the corresponding cat.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Görsel klasörleri, iPhone yeniden başlatıldıktan sonraki ilk kilit açmaya kadar iOS korumasındadır; yedeklenmez ve ilgili kediyle birlikte silinir."
          }
        }
      }
    },
    "Keep Draft": {
      "comment": "Safe action that closes the discard confirmation and preserves the current draft.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Taslağı Koru"
          }
        }
      }
    },
    "Middle": {
      "comment": "Section title for the middle row of accessible photo-selection regions.",
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orta"
          }
        }
      }
    },
    "No camera is available on this device.": {
      "comment": "Camera error shown when no camera is available, including on Simulator.",
