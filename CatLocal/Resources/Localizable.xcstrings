    "No account, public map, advertising identifier, GPS tracking, cloud AI, or model-training upload.": {
      "localizations": {
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χωρίς λογαριασμό, δημόσιο χάρτη, αναγνωριστικό διαφήμισης, παρακολούθηση GPS, τεχνητή νοημοσύνη στο cloud ή μεταφόρτωση για εκπαίδευση μοντέλων."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez računa, javne karte, oglasnog identifikatora, GPS praćenja, AI-ja u oblaku ili prijenosa za treniranje modela."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez konta, publicznej mapy, identyfikatora reklamowego, śledzenia GPS, AI w chmurze i przesyłania do trenowania modeli."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fără cont, hartă publică, identificator publicitar, urmărire GPS, AI în cloud sau încărcare pentru antrenarea modelelor."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesap, herkese açık harita, reklam tanımlayıcı, GPS takibi, bulut yapay zekâsı veya model eğitimi yüklemesi yoktur."
